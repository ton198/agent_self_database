# Anthropic Claude API — gate + hint are both cloud (Messages API)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
# Optional proxy / VPC endpoint; leave empty for https://api.anthropic.com
# ANTHROPIC_BASE_URL=

# Model IDs: https://docs.anthropic.com/en/docs/about-claude/models
# Gate: cheap — Haiku 4.5 alias (do NOT use "claude-haiku-3", not a valid API id)
CLAUDE_GATE_MODEL=claude-haiku-4-5
# Hint / popup (can be same or snapshot id)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Backward-compatible aliases: CLOUD_LLM_API_KEY, CLOUD_LLM_MODEL, CLOUD_GATE_MODEL

# Optional tuning
# Windows: capture only foreground window (default true). false = whole primary monitor.
CAPTURE_ACTIVE_WINDOW_ONLY=true
# Max width/height of PNG sent to Claude (uniform scale)
# VISION_MAX_IMAGE_SIDE=1280
CAPTURE_INTERVAL_SECONDS=2.0
PROACTIVE_INTERVAL_SECONDS=60
RECENT_CONTEXT_MINUTES=12
FRAME_DIFF_THRESHOLD=4.0
MIN_NOTIFY_COOLDOWN_SECONDS=300
MAX_NOTIFIES_PER_DAY=30
RAG_TOP_K=6
OCR_MERGE_SECONDS=45
